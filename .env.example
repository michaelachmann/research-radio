# Google Cloud Configuration
# Path to your service account JSON file (needs Drive API access)
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Google Drive folder ID where PaperPile stores PDFs
# (Get this from your Drive folder URL: drive.google.com/drive/folders/FOLDER_ID)
GOOGLE_DRIVE_FOLDER_ID=1gluNDqRQkyqxa_WIASaaoNEItrDlETkn

# Anthropic / Claude
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key
# Model to use — swap for claude-opus-4-6 for higher quality
CLAUDE_MODEL=claude-sonnet-4-6

# ElevenLabs TTS
# Get from: https://elevenlabs.io/
ELEVENLABS_API_KEY=your-elevenlabs-api-key
# Voice IDs from your ElevenLabs voice library
ELEVENLABS_HOST_VOICE_ID=your-host-voice-id
ELEVENLABS_COHOST_VOICE_ID=your-cohost-voice-id
# Names spoken in the script (not voice IDs — pick any names you like)
TTS_HOST_NAME=Alex
TTS_COHOST_NAME=Sam

# GitHub Configuration (for uploading releases)
GITHUB_TOKEN=your-github-personal-access-token
GITHUB_REPO=username/research-radio

# Feed Configuration
FEED_URL=https://raw.githubusercontent.com/fabiogiglietto/toread/main/output/feed.json

# Podcast Metadata
PODCAST_TITLE=Research Radio
PODCAST_DESCRIPTION=AI-generated podcast discussions of academic papers
PODCAST_AUTHOR=Research Radio
PODCAST_EMAIL=your-email@example.com
PODCAST_WEBSITE=https://username.github.io/research-radio

# Analyzer Configuration
# Comma-separated list of analyzers to run per paper
# Available: podcast, extraction, critical
ENABLED_ANALYZERS=podcast,extraction,critical
